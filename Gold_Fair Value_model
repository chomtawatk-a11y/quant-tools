<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Gold Fair Value Calculator</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500&family=IBM+Plex+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#FAFAF8;--bg2:#F4F2EE;--bg3:#EDEAE4;
  --border:#D8D3C8;--border2:#C8C2B4;
  --ink:#1C1A16;--ink2:#3D3A32;--muted:#7A7468;--faint:#A8A298;
  --gold:#9A6E1A;--gold-bg:#FDF6E8;--gold-mid:#C48A2A;--gold-lt:#F0E4C0;
  --green:#1A6B3A;--green-bg:#EEF8F2;
  --red:#8B2020;--red-bg:#FDF0F0;
  --blue:#1A4A7A;--blue-bg:#EEF4FB;
  --teal:#1A5A4A;--teal-bg:#EEF8F5;
  --orange:#7A4A00;--orange-bg:#FFF8EE;--orange-border:#E0C070;
}
body{font-family:'IBM Plex Sans',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh;font-size:14px}

/* ── TOPBAR ── */
.topbar{background:var(--ink);padding:0 28px;display:flex;align-items:center;justify-content:space-between;height:48px;border-bottom:2px solid var(--gold-mid);position:sticky;top:0;z-index:100}
.topbar-brand{font-family:'IBM Plex Mono',monospace;font-size:13px;letter-spacing:2px;color:#D4A840;font-weight:500}
.topbar-pills{display:flex;gap:8px}
.tpill{font-family:'IBM Plex Mono',monospace;font-size:10px;padding:3px 10px;border-radius:2px;letter-spacing:1px}
.tp-r2{background:rgba(26,90,74,0.3);color:#7ADFC0;border:1px solid rgba(26,90,74,0.4)}
.tp-date{background:rgba(201,168,76,0.15);color:#D4A840;border:1px solid rgba(201,168,76,0.25)}

/* ── 2-COL LAYOUT ── */
.page{display:grid;grid-template-columns:360px 1fr;min-height:calc(100vh - 48px)}

/* ══ LEFT PANEL ══ */
.left{background:white;border-right:1px solid var(--border);display:flex;flex-direction:column;overflow-y:auto;position:sticky;top:48px;height:calc(100vh - 48px)}
.left-hdr{padding:18px 22px 14px;border-bottom:1px solid var(--border)}
.left-hdr h2{font-size:15px;font-weight:600;color:var(--ink);margin-bottom:3px}
.left-hdr p{font-size:11px;color:var(--muted);font-style:italic;font-family:'IBM Plex Mono',monospace}

/* ACTUAL GOLD INPUT */
.actual-input-section{padding:14px 22px;border-bottom:1px solid var(--border);background:var(--gold-bg)}
.ai-label{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--gold);margin-bottom:8px}
.ai-row{display:flex;align-items:center;gap:10px}
.ai-prefix{font-family:'IBM Plex Mono',monospace;font-size:18px;font-weight:600;color:var(--gold-mid)}
.ai-input{font-family:'IBM Plex Mono',monospace;font-size:22px;font-weight:600;color:var(--ink);border:none;border-bottom:2px solid var(--gold-mid);background:transparent;width:140px;outline:none;padding:2px 4px}
.ai-input:focus{border-bottom-color:var(--gold)}
.ai-unit{font-family:'IBM Plex Mono',monospace;font-size:11px;color:var(--muted)}
.ai-hint{font-size:10px;color:var(--gold);font-style:italic;margin-top:5px}

/* MODEL TABS */
.model-tabs{display:flex;border-bottom:1px solid var(--border)}
.mtab{flex:1;padding:9px 0;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.5px;text-transform:uppercase;cursor:pointer;border:none;background:var(--bg2);color:var(--muted);transition:all 0.15s;border-bottom:2px solid transparent}
.mtab.active{background:white;color:var(--ink);font-weight:500;border-bottom-color:var(--gold-mid)}

/* FACTOR SLIDERS */
.factors-scroll{flex:1;overflow-y:auto;padding:14px 22px}
.sec-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--faint);margin-bottom:10px;margin-top:16px;display:flex;align-items:center;gap:8px}
.sec-lbl:first-child{margin-top:0}
.sec-lbl::after{content:'';flex:1;height:1px;background:var(--border)}

.fr{margin-bottom:14px}
.fr-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:2px}
.fr-name{font-size:11px;font-weight:600}
.fr-ticker{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--faint);margin-left:4px}
.fr-rhs{display:flex;align-items:center;gap:6px}
.fr-val{font-family:'IBM Plex Mono',monospace;font-size:13px;font-weight:600}
.fr-unit{font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted)}
.fr-chg{font-family:'IBM Plex Mono',monospace;font-size:9px;padding:1px 5px;border-radius:2px;min-width:36px;text-align:center}
.chg-up{background:var(--green-bg);color:var(--green)}.chg-dn{background:var(--red-bg);color:var(--red)}.chg-flat{color:var(--faint)}
.fr-hint{font-size:10px;color:var(--faint);font-style:italic;margin-bottom:4px}
input[type=range]{width:100%;height:3px;-webkit-appearance:none;background:var(--border);border-radius:2px;outline:none;cursor:pointer}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;border-radius:50%;cursor:pointer;border:2px solid white;box-shadow:0 1px 3px rgba(0,0,0,.2);transition:transform .1s}
input[type=range]:hover::-webkit-slider-thumb{transform:scale(1.25)}

.reset-btn{width:100%;padding:8px;background:transparent;border:1px solid var(--border);border-radius:3px;font-family:'IBM Plex Mono',monospace;font-size:10px;color:var(--muted);cursor:pointer;transition:all .15s;margin-top:8px;letter-spacing:.5px}
.reset-btn:hover{border-color:var(--border2);color:var(--ink2)}

/* ══ RIGHT PANEL ══ */
.right{padding:22px 26px;display:flex;flex-direction:column;gap:16px;overflow:auto}

/* RESULT HERO */
.hero{background:white;border:1px solid var(--border);border-radius:5px;padding:22px 24px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:0;left:0;right:0;height:3px}
.hero-bull::before{background:linear-gradient(90deg,var(--green),#7ADFC0)}
.hero-bear::before{background:linear-gradient(90deg,var(--red),#FF9090)}
.hero-fair::before{background:linear-gradient(90deg,var(--gold-mid),var(--gold-lt))}
.hero-grid{display:grid;grid-template-columns:1fr auto;gap:16px;align-items:start;margin-bottom:14px}
.hero-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:5px}
.hero-price{font-size:48px;font-weight:600;letter-spacing:-2px;line-height:1;margin-bottom:4px}
.hero-sub{font-size:12px;color:var(--muted);font-style:italic}
.hero-right{text-align:right}
.hero-actual-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--faint);margin-bottom:3px}
.hero-actual{font-size:22px;font-weight:600;color:var(--ink2);letter-spacing:-.5px;font-family:'IBM Plex Mono',monospace}
.hero-gap{font-family:'IBM Plex Mono',monospace;font-size:13px;font-weight:600;margin-top:4px}
.gap-over{color:var(--red)}.gap-under{color:var(--green)}.gap-fair{color:var(--gold)}

/* VERDICT */
.verdict{border-radius:4px;padding:11px 14px;display:flex;align-items:flex-start;gap:10px}
.v-icon{font-size:20px;flex-shrink:0;margin-top:1px}
.v-text{font-size:12px;font-weight:600;line-height:1.4}
.v-sub{font-size:11px;font-weight:400;margin-top:3px;opacity:.85;line-height:1.4}
.v-over{background:var(--red-bg);border:1px solid #DDA0A0;color:var(--red)}
.v-under{background:var(--green-bg);border:1px solid #90C0A0;color:var(--green)}
.v-fair{background:var(--gold-bg);border:1px solid rgba(184,146,42,.4);color:var(--gold)}
.v-warn{background:var(--orange-bg);border:1px solid var(--orange-border);color:var(--orange)}

/* MOMENTUM HEALTH PANEL */
.mom-panel{background:white;border:1px solid var(--border);border-radius:5px;overflow:hidden}
.mp-header{padding:11px 16px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.mp-title{font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted)}
.mp-badge{font-family:'IBM Plex Mono',monospace;font-size:10px;padding:3px 10px;border-radius:2px;font-weight:600}
.mb-hot{background:#FDEEE8;color:#8B3000;border:1px solid #EDB090}
.mb-warm{background:var(--orange-bg);color:var(--orange);border:1px solid var(--orange-border)}
.mb-ok{background:var(--green-bg);color:var(--green);border:1px solid #90C0A0}
.mb-cold{background:var(--blue-bg);color:var(--blue);border:1px solid #A0BFDF}

.mp-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:0;border-bottom:1px solid var(--border)}
.mp-cell{padding:12px 14px;border-right:1px solid var(--border)}
.mp-cell:last-child{border-right:none}
.mp-cell-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--faint);margin-bottom:5px}
.mp-cell-val{font-size:16px;font-weight:600;letter-spacing:-.3px;margin-bottom:2px;font-family:'IBM Plex Mono',monospace}
.mp-cell-sub{font-size:10px;color:var(--muted);font-style:italic}

/* PERCENTILE GAUGE */
.pct-gauge-wrap{padding:12px 16px;border-bottom:1px solid var(--border)}
.pct-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1px;text-transform:uppercase;color:var(--faint);margin-bottom:8px;display:flex;justify-content:space-between}
.pct-track{height:10px;border-radius:5px;position:relative;overflow:visible;margin-bottom:6px}
.pct-fill{height:100%;border-radius:5px;position:absolute;left:0}
.pct-marker{position:absolute;top:-3px;width:4px;height:16px;border-radius:2px;background:var(--ink);transform:translateX(-50%)}
.pct-zones{display:grid;grid-template-columns:repeat(4,1fr);margin-top:4px}
.pz{font-family:'IBM Plex Mono',monospace;font-size:8px;text-align:center;padding:2px}

/* SIGNALS TABLE */
.signals-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:0;border-top:1px solid var(--border)}
.sig-cell{padding:11px 14px;border-right:1px solid var(--border);border-bottom:1px solid var(--border)}
.sig-cell:nth-child(2n){border-right:none}
.sig-cell:nth-last-child(-n+2){border-bottom:none}
.sig-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px}
.sig-name{font-size:11px;font-weight:600}
.sig-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.dot-green{background:var(--green)}.dot-red{background:var(--red)}.dot-yellow{background:#D4A840}.dot-gray{background:var(--faint)}
.sig-val{font-family:'IBM Plex Mono',monospace;font-size:12px;font-weight:600}
.sig-desc{font-size:10px;color:var(--muted);font-style:italic;margin-top:2px}

/* 4-METRIC ROW */
.metrics-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.mcard{background:white;border:1px solid var(--border);border-radius:4px;padding:12px 14px;position:relative;overflow:hidden}
.mcard::after{content:'';position:absolute;left:0;top:0;bottom:0;width:3px}
.mc-gold::after{background:var(--gold-mid)}.mc-blue::after{background:#3A7ABF}
.mc-green::after{background:#2A8A4A}.mc-red::after{background:#BF3A3A}
.mc-teal::after{background:var(--teal)}
.mc-lbl{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--faint);margin-bottom:5px}
.mc-val{font-size:17px;font-weight:600;line-height:1;margin-bottom:3px;letter-spacing:-.3px}
.mc-sub{font-size:10px;color:var(--muted);font-style:italic}

/* SENSITIVITY TABLE */
.sens-card{background:white;border:1px solid var(--border);border-radius:4px;overflow:hidden}
.sens-hdr{padding:9px 16px;background:var(--bg2);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.sens-hdr-title{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--muted)}
table{width:100%;border-collapse:collapse}
th{padding:8px 14px;text-align:left;font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--faint);background:var(--bg2);border-bottom:1px solid var(--border);font-weight:400}
td{padding:9px 14px;font-size:11px;border-bottom:1px solid var(--bg3);color:var(--ink2);vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--bg2)}
.td-m{font-family:'IBM Plex Mono',monospace;font-size:10px}
.td-pos{color:var(--green)}.td-neg{color:var(--red)}
.mini-bar-wrap{display:flex;align-items:center;gap:5px}
.mini-bar{height:5px;border-radius:3px;display:inline-block}

/* CHART */
.chart-card{background:white;border:1px solid var(--border);border-radius:4px;padding:15px 17px}
.chart-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;flex-wrap:wrap;gap:8px}
.chart-title{font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted)}
.legend-row{display:flex;gap:12px;flex-wrap:wrap}
.leg-item{display:flex;align-items:center;gap:5px;font-size:10px;color:var(--muted);font-family:'IBM Plex Mono',monospace}
.leg-line{width:14px;height:2px;border-radius:1px}
.period-row{display:flex;gap:4px}
.pb{padding:3px 9px;border:1px solid var(--border);background:white;border-radius:2px;font-family:'IBM Plex Mono',monospace;font-size:9px;cursor:pointer;color:var(--muted);transition:all .1s}
.pb.active{background:var(--ink);color:white;border-color:var(--ink)}

.notif{position:fixed;bottom:20px;right:20px;background:var(--ink);color:#F0EDE6;padding:10px 14px;border-radius:3px;font-size:11px;font-family:'IBM Plex Mono',monospace;z-index:999;opacity:0;transform:translateY(10px);transition:all .2s;pointer-events:none}
.notif.show{opacity:1;transform:translateY(0)}

@media(max-width:1050px){.page{grid-template-columns:1fr;}.left{position:static;height:auto}.metrics-row{grid-template-columns:1fr 1fr}}
</style>
</head>
<body>

<div class="topbar">
  <span class="topbar-brand">◈ GOLD FAIR VALUE CALCULATOR</span>
  <div class="topbar-pills">
    <span class="tpill tp-r2" id="top-r2">Post-2022 · R² 96.2%</span>
    <span class="tpill tp-date">Bloomberg · Feb 2026 · 254 obs</span>
  </div>
</div>

<div class="page">

<!-- ══════════ LEFT ══════════ -->
<div class="left">
  <div class="left-hdr">
    <h2>ตั้ง Assumptions → ดูราคาทองที่ควรเป็น</h2>
    <p>ขยับ slider · ราคาอัปเดตทันที</p>
  </div>

  <!-- ACTUAL GOLD INPUT -->
  <div class="actual-input-section">
    <div class="ai-label">ราคาทองจริงที่ต้องการเปรียบเทียบ</div>
    <div class="ai-row">
      <span class="ai-prefix">$</span>
      <input type="number" class="ai-input" id="actual-input" value="5278.93" min="100" max="20000" step="1" oninput="recalc()">
      <span class="ai-unit">/ oz</span>
    </div>
    <div class="ai-hint">แก้ไขได้ตรงนี้เพื่อเปรียบเทียบกับราคาปัจจุบันหรืออนาคต</div>
  </div>

  <!-- MODEL TABS -->
  <div class="model-tabs">
    <button class="mtab active" id="mtab-post" onclick="selectModel('post',this)">Post-2022 ★ R²=96%</button>
    <button class="mtab" id="mtab-full" onclick="selectModel('full',this)">Full 8F R²=70%</button>
  </div>

  <!-- SLIDERS -->
  <div class="factors-scroll">

    <div class="sec-lbl">Macro Fundamentals</div>

    <div class="fr">
      <div class="fr-top">
        <span><span class="fr-name" style="color:#1A4A7A">Real Rate (10Y TIPS)</span><span class="fr-ticker">USGGBE10</span></span>
        <div class="fr-rhs"><span class="fr-val" id="fv-rr" style="color:#1A4A7A">2.26</span><span class="fr-unit">%</span><span class="fr-chg chg-flat" id="fc-rr"></span></div>
      </div>
      <div class="fr-hint">ลด → ทองขึ้น · ปัจจุบัน 2.26%</div>
      <input type="range" id="sl-rr" min="-3" max="5" step="0.05" value="2.26">
    </div>

    <div class="fr">
      <div class="fr-top">
        <span><span class="fr-name" style="color:#1A6B3A">DXY Dollar Index</span><span class="fr-ticker">DXY Curncy</span></span>
        <div class="fr-rhs"><span class="fr-val" id="fv-dxy" style="color:#1A6B3A">97.6</span><span class="fr-chg chg-flat" id="fc-dxy"></span></div>
      </div>
      <div class="fr-hint">แข็งค่า → ทองลง · ปัจจุบัน 97.6</div>
      <input type="range" id="sl-dxy" min="80" max="120" step="0.5" value="97.6">
    </div>

    <div class="fr">
      <div class="fr-top">
        <span><span class="fr-name" style="color:#8B2020">CPI YoY (US)</span><span class="fr-ticker">CPI YOY Index</span></span>
        <div class="fr-rhs"><span class="fr-val" id="fv-cpi" style="color:#8B2020">2.4</span><span class="fr-unit">%</span><span class="fr-chg chg-flat" id="fc-cpi"></span></div>
      </div>
      <div class="fr-hint">เงินเฟ้อ · ปัจจุบัน 2.4%</div>
      <input type="range" id="sl-cpi" min="0" max="12" step="0.1" value="2.4">
    </div>

    <div class="fr">
      <div class="fr-top">
        <span><span class="fr-name" style="color:#7A3A10">WTI Crude Oil</span><span class="fr-ticker">CL1 Comdty</span></span>
        <div class="fr-rhs"><span class="fr-val" id="fv-wti" style="color:#7A3A10">67.0</span><span class="fr-unit">$/bbl</span><span class="fr-chg chg-flat" id="fc-wti"></span></div>
      </div>
      <div class="fr-hint">Indirect ผ่าน CPI · ปัจจุบัน $67.0</div>
      <input type="range" id="sl-wti" min="20" max="150" step="1" value="67.0">
    </div>

    <div class="fr">
      <div class="fr-top">
        <span><span class="fr-name" style="color:#5A2A7A">VIX Index</span><span class="fr-ticker">VIX Index</span></span>
        <div class="fr-rhs"><span class="fr-val" id="fv-vix" style="color:#5A2A7A">19.9</span><span class="fr-chg chg-flat" id="fc-vix"></span></div>
      </div>
      <div class="fr-hint">สูง = กลัว → Safe haven · ปัจจุบัน 19.9</div>
      <input type="range" id="sl-vix" min="10" max="80" step="0.5" value="19.9">
    </div>

    <div class="sec-lbl">Momentum & Demand</div>

    <div class="fr">
      <div class="fr-top">
        <span><span class="fr-name" style="color:#C48A2A">Price Momentum (12M)</span><span class="fr-ticker">จาก XAU price</span></span>
        <div class="fr-rhs"><span class="fr-val" id="fv-momentum" style="color:#C48A2A">0.85</span><span class="fr-unit">× (84.7%)</span><span class="fr-chg chg-flat" id="fc-momentum"></span></div>
      </div>
      <div class="fr-hint">12M Return ทอง — ตอนนี้ <strong>ที่ 100th percentile</strong> ของ 20Y history</div>
      <input type="range" id="sl-momentum" min="-0.5" max="2.0" step="0.01" value="0.85">
    </div>

    <div class="fr">
      <div class="fr-top">
        <span><span class="fr-name" style="color:#2A7A5A">GLD ETF Shares (CB Proxy)</span><span class="fr-ticker">GLD EQY_SH_OUT</span></span>
        <div class="fr-rhs"><span class="fr-val" id="fv-gld" style="color:#2A7A5A">385.0</span><span class="fr-unit">M shares</span><span class="fr-chg chg-flat" id="fc-gld"></span></div>
      </div>
      <div class="fr-hint">Institutional/CB demand proxy · ปัจจุบัน 385.0M</div>
      <input type="range" id="sl-gld" min="100" max="1200" step="5" value="385.0">
    </div>

    <div class="fr" id="fr-m2" style="opacity:.45">
      <div class="fr-top">
        <span><span class="fr-name" style="color:#2A4A8A">World M2 % GDP</span><span class="fr-ticker">M2MGWWLD Index</span></span>
        <div class="fr-rhs"><span class="fr-val" id="fv-m2" style="color:#2A4A8A">117.3</span><span class="fr-unit">%</span><span class="fr-chg chg-flat" id="fc-m2"></span></div>
      </div>
      <div class="fr-hint">Global liquidity — Full model only · ปัจจุบัน 117.3%</div>
      <input type="range" id="sl-m2" min="90" max="130" step="0.5" value="117.3">
