const MOM_SORTED = [-0.2828, -0.2692, -0.2519, -0.2501, -0.2311, -0.2272, -0.1962, -0.1793, -0.1753, -0.1603, -0.1456, -0.129, -0.1254, -0.1184, -0.1168, -0.1135, -0.113, -0.1107, -0.1041, -0.0995, -0.0916, -0.091, -0.091, -0.0879, -0.0854, -0.084, -0.083, -0.0818, -0.0784, -0.0782, -0.0774, -0.077, -0.0732, -0.0694, -0.069, -0.0686, -0.0683, -0.0607, -0.0606, -0.0566, -0.0548, -0.0508, -0.0473, -0.0446, -0.043, -0.0427, -0.0426, -0.0424, -0.0365, -0.0364, -0.0357, -0.0324, -0.0321, -0.0274, -0.0273, -0.0266, -0.0263, -0.025, -0.0242, -0.0195, -0.018, -0.0178, -0.0156, -0.0144, -0.0077, -0.0061, -0.0045, -0.0038, -0.0034, -0.0028, -0.0014, 0.0012, 0.0019, 0.0027, 0.0035, 0.0054, 0.0079, 0.0089, 0.0095, 0.0121, 0.0133, 0.0161, 0.0164, 0.0208, 0.021, 0.021, 0.0233, 0.0237, 0.0315, 0.0367, 0.0371, 0.0416, 0.0433, 0.0436, 0.044, 0.0441, 0.049, 0.0491, 0.0549, 0.056, 0.0576, 0.058, 0.0611, 0.062, 0.0646, 0.0648, 0.0682, 0.0706, 0.0722, 0.073, 0.0733, 0.0752, 0.0814, 0.0827, 0.0828, 0.0868, 0.0914, 0.0922, 0.0936, 0.1009, 0.101, 0.1018, 0.1021, 0.1045, 0.111, 0.1128, 0.1132, 0.1183, 0.119, 0.1253, 0.1276, 0.131, 0.1323, 0.1339, 0.1345, 0.1353, 0.1373, 0.1444, 0.1482, 0.1489, 0.1515, 0.1533, 0.1549, 0.157, 0.1627, 0.1647, 0.1653, 0.1713, 0.1751, 0.1801, 0.1831, 0.1858, 0.186, 0.192, 0.1995, 0.2022, 0.2028, 0.2074, 0.2075, 0.2092, 0.2109, 0.2123, 0.2138, 0.2145, 0.2204, 0.2315, 0.2326, 0.2331, 0.2344, 0.2365, 0.2379, 0.2409, 0.2418, 0.2422, 0.2429, 0.2437, 0.2455, 0.2455, 0.2512, 0.2598, 0.2614, 0.2626, 0.2628, 0.2635, 0.2658, 0.2722, 0.2749, 0.2807, 0.2865, 0.289, 0.2903, 0.2935, 0.2943, 0.2957, 0.2979, 0.2985, 0.3003, 0.304, 0.304, 0.3094, 0.3114, 0.3136, 0.314, 0.3142, 0.3253, 0.3263, 0.3274, 0.3409, 0.3422, 0.3441, 0.3462, 0.3626, 0.3721, 0.376, 0.3773, 0.3777, 0.3813, 0.3831, 0.3976, 0.398, 0.4008, 0.4133, 0.4141, 0.4178, 0.4196, 0.4245, 0.4252, 0.4385, 0.4414, 0.442, 0.4443, 0.455, 0.4588, 0.4635, 0.4647, 0.4815, 0.5065, 0.5463, 0.6039, 0.6458, 0.7489, 0.8472];
function momPercentile(val) {
  const below = MOM_SORTED.filter(v => v <= val).length;
  return Math.round(below / MOM_SORTED.length * 100);
}

const DEFAULTS = {
  rr: 2.26, dxy: 97.6, cpi: 2.4,
  wti: 67.0, vix: 19.9,
  momentum: 0.85, gld: 385.0, m2: 117.3
};

let currentModel = 'post';
let periodSlice = 0;
let chartInst = null;
let isScenario = false;

// Thumb colors
const tc = document.createElement('style');
tc.textContent = `#sl-rr::-webkit-slider-thumb{background:#1A4A7A}#sl-dxy::-webkit-slider-thumb{background:#1A6B3A}#sl-cpi::-webkit-slider-thumb{background:#8B2020}#sl-wti::-webkit-slider-thumb{background:#7A3A10}#sl-vix::-webkit-slider-thumb{background:#5A2A7A}#sl-momentum::-webkit-slider-thumb{background:#C48A2A}#sl-gld::-webkit-slider-thumb{background:#2A7A5A}#sl-m2::-webkit-slider-thumb{background:#2A4A8A}`;
document.head.appendChild(tc);

['rr','dxy','cpi','wti','vix','momentum','gld','m2'].forEach(k => {
  document.getElementById('sl-'+k).addEventListener('input', () => { isScenario=true; recalc(); });
});
document.getElementById('actual-input').addEventListener('input', recalc);

function getVals() {
  return Object.fromEntries(['rr','dxy','cpi','wti','vix','momentum','gld','m2'].map(k => [k, parseFloat(document.getElementById('sl-'+k).value)]));
}
function getActual() {
  const v = parseFloat(document.getElementById('actual-input').value);
  return isNaN(v) ? 5278.93 : v;
}

function fairPrice(vals, model) {
  const {b, keys} = BETAS[model];
  return b[0] + keys.reduce((s,k,i) => s + b[i+1]*(vals[k]||0), 0);
}

function selectModel(m, el) {
  currentModel = m;
  document.querySelectorAll('.mtab').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('fr-m2').style.opacity = m==='full'?'1':'0.45';
  document.getElementById('top-r2').textContent = BETAS[m].label;
  recalc();
}

function resetAll() {
  Object.entries(DEFAULTS).forEach(([k,v]) => { document.getElementById('sl-'+k).value = v; });
  document.getElementById('actual-input').value = '5278.93';
  isScenario = false;
  recalc();
  notify('Reset เป็นค่า Feb 2026 แล้ว');
}

function recalc() {
  const vals = getVals();
  const actual = getActual();
  const bm = BETAS[currentModel];
  const fair = fairPrice(vals, currentModel);
  const gap = actual - fair;
  const gapPct = (gap/fair*100);

  // Slider labels + change badges
  FACTOR_META.forEach(f => {
    const v = vals[f.key];
    const el_val = document.getElementById('fv-'+f.key);
    const el_chg = document.getElementById('fc-'+f.key);
    if (el_val) el_val.textContent = v.toFixed(f.fmt);
    if (el_chg) {
      const diff = v - DEFAULTS[f.key];
      if (Math.abs(diff) < Math.pow(10,-f.fmt)*0.6) {
        el_chg.textContent=''; el_chg.className='fr-chg chg-flat';
      } else {
        const sign = diff>0?'+':'';
        el_chg.textContent = sign+diff.toFixed(f.fmt);
        el_chg.className = 'fr-chg '+(diff>0?'chg-up':'chg-dn');
      }
    }
  });

  // Hero
  document.getElementById('hero-price').textContent = '$'+Math.round(fair).toLocaleString('en');
  document.getElementById('hero-actual').textContent = '$'+actual.toLocaleString('en',{maximumFractionDigits:0});
  document.getElementById('hero-lbl').textContent = `Scenario Fair Value — ${bm.label}`;
  document.getElementById('m-fair').textContent = '$'+Math.round(fair).toLocaleString('en');
  document.getElementById('m-fair-sub').textContent = bm.label;
  document.getElementById('sens-model-lbl').textContent = currentModel==='post'?'Post-2022 β':'Full 8F β';

  const gEl = document.getElementById('hero-gap');
  gEl.textContent = (gap>=0?'Overvalued +':'Undervalued ')+(gap>=0?'+':'')+Math.round(gap).toLocaleString('en')+' ('+gapPct.toFixed(1)+'%)';
  gEl.className = 'hero-gap '+(gap>0?'gap-over':gap<0?'gap-under':'gap-fair');

  document.getElementById('m-misprice').textContent = (gap>=0?'+':'')+Math.round(gap).toLocaleString('en');
  document.getElementById('m-misprice').className = 'mc-val '+(gap>0?'c-red':'c-green');  // fixed class
  document.getElementById('m-misprice-sub').textContent = (gap>=0?'Overvalued +':'Undervalued ')+Math.abs(gapPct).toFixed(1)+'%';

  // Hero class
  const hero = document.getElementById('hero');
  hero.className = 'hero '+(gapPct>10?'hero-bear':gapPct<-10?'hero-bull':'hero-fair');

  // Verdict
  const vbox=document.getElementById('verdict'), vicon=document.getElementById('v-icon');
  const vtxt=document.getElementById('v-text'), vsub=document.getElementById('v-sub');
  if (gapPct > 20) {
    vbox.className='verdict v-over'; vicon.textContent='⚠️';
    vtxt.textContent=`Overvalued มาก +${gapPct.toFixed(1)}% — Momentum Overshoot สูงมาก`;
    vsub.textContent='KS: ไม่แนะนำ Add position · รอ Pullback หรือ Catalyst Fundamental ใหม่';
  } else if (gapPct > 8) {
    vbox.className='verdict v-warn'; vicon.textContent='🔸';
    vtxt.textContent=`Overvalued เล็กน้อย +${gapPct.toFixed(1)}% — Momentum ยังหนุน แต่ Stretched`;
    vsub.textContent='Upside เพิ่มเติมมาจาก CB Demand ที่ Model ยังขาด · Hold ไม่ใช่ Chase';
  } else if (gapPct > -5) {
    vbox.className='verdict v-fair'; vicon.textContent='⚖️';
    vtxt.textContent=`Fair Value ±${Math.abs(gapPct).toFixed(1)}% — ราคาสะท้อน Assumptions แล้ว`;
    vsub.textContent='Fundamental รองรับราคาปัจจุบัน · Momentum เป็น bonus';
  } else if (gapPct > -15) {
    vbox.className='verdict v-under'; vicon.textContent='🔹';
    vtxt.textContent=`Undervalued ${Math.abs(gapPct).toFixed(1)}% — Scenario นี้ให้ Upside`;
    vsub.textContent='ถ้า Assumptions เป็นจริง ราคาควรขึ้นไป $'+Math.round(fair).toLocaleString('en');
  } else {
    vbox.className='verdict v-under'; vicon.textContent='🟢';
    vtxt.textContent=`Undervalued มาก ${Math.abs(gapPct).toFixed(1)}% — Strong Bullish Signal`;
    vsub.textContent='Fundamental แข็งแกร่ง · ราคาควรขึ้นมาก';
  }

  // MOMENTUM HEALTH
  const mom = vals.momentum;
  const momPct = momPercentile(mom);
  const momReturn = (mom*100).toFixed(1)+'%';
  document.getElementById('mom-return').textContent = momReturn;
  document.getElementById('mom-pct').textContent = momPct+'th';
  document.getElementById('mom-pct').style.color = momPct>75?'var(--red)':momPct>50?'var(--orange)':'var(--green)';
  document.getElementById('mom-fundgap').textContent = (gapPct>=0?'+':'')+gapPct.toFixed(1)+'%';
  document.getElementById('mom-fundgap').style.color = gapPct>8?'var(--red)':gapPct<-5?'var(--green)':'var(--gold)';
  document.getElementById('m-momentum').textContent = momReturn;

  // Percentile gauge marker
  document.getElementById('pct-marker').style.left = momPct+'%';
  document.getElementById('pct-current-label').textContent = momPct+'th percentile';
  document.getElementById('pct-current-label').style.color = momPct>75?'var(--red)':momPct>50?'var(--orange)':'var(--green)';

  // Mom badge
  const mbadge = document.getElementById('mom-badge');
  if (momPct>=90){mbadge.textContent='🔥 Extreme ('+momPct+'th)';mbadge.className='mp-badge mb-hot';}
  else if (momPct>=75){mbadge.textContent='⚡ Hot ('+momPct+'th)';mbadge.className='mp-badge mb-warm';}
  else if (momPct>=40){mbadge.textContent='✓ Healthy ('+momPct+'th)';mbadge.className='mp-badge mb-ok';}
  else {mbadge.textContent='❄️ Cold ('+momPct+'th)';mbadge.className='mp-badge mb-cold';}

  // Signal cells
  const gldVal = vals.gld;
  const gldBaseline = DEFAULTS.gld;
  const realRate = vals.rr;

  // Signal 1: Momentum stretch
  const s1 = momPct;
  setSignal(1,
    s1>=90 ? 'red' : s1>=75 ? 'yellow' : 'green',
    s1+'th percentile',
    s1>=90?'🔥 Extreme — ความเสี่ยง Mean Reversion สูง':s1>=75?'⚡ Stretched — Caution เพิ่ม':'✓ Healthy — ยังไปต่อได้'
  );

  // Signal 2: Fundamental support (fair vs actual)
  setSignal(2,
    Math.abs(gapPct)<8?'green':gapPct>15?'red':'yellow',
    Math.abs(gapPct).toFixed(1)+'% gap',
    Math.abs(gapPct)<8?'✓ Fundamental รองรับราคา':gapPct>15?'⚠️ Actual เกิน Fair Value มาก':'⚡ เกินนิดหน่อย — CB Demand ช่วยรับ'
  );

  // Signal 3: GLD demand
  const gldChg = gldVal - gldBaseline;
  setSignal(3,
    gldChg>20?'green':gldChg<-20?'red':'yellow',
    (gldChg>=0?'+':'')+Math.round(gldChg)+'M shares',
    gldChg>20?'✓ Inflows แรง — Institutional ยังซื้อ':gldChg<-20?'⚠️ Outflows — Demand อ่อนแอ':'➡ Stable — ไม่มี Catalyst ใหม่'
  );

  // Signal 4: Macro backdrop (Real Rate)
  setSignal(4,
    realRate<0?'green':realRate<1.5?'yellow':'red',
    realRate.toFixed(2)+'% Real Rate',
    realRate<0?'✓ Real Rate ติดลบ — Favorable มาก':realRate<1.5?'⚡ Real Rate บวกเล็กน้อย — OK':
    '⚠️ Real Rate สูง — Headwind สำหรับทอง'
  );

  // Overall signal
  const signals = [
    s1<75?1:s1<90?0:-1,
    Math.abs(gapPct)<8?1:gapPct>15?-1:0,
    gldChg>20?1:gldChg<-20?-1:0,
    realRate<0?1:realRate<1.5?0:-1,
  ];
  const score = signals.reduce((a,b)=>a+b,0);
  const sigEl = document.getElementById('m-signal');
  const sigSub = document.getElementById('m-signal-sub');
  const sigCard = document.getElementById('mc-signal');
  if (score>=2){sigEl.textContent='BULLISH';sigEl.style.color='var(--green)';sigSub.textContent='Momentum + Fundamental ok';sigCard.className='mcard mc-green';}
  else if (score>=0){sigEl.textContent='NEUTRAL';sigEl.style.color='var(--gold)';sigSub.textContent='Mixed signals';sigCard.className='mcard mc-gold';}
  else{sigEl.textContent='CAUTION';sigEl.style.color='var(--red)';sigSub.textContent='Stretched momentum';sigCard.className='mcard mc-red';}

  // Sensitivity table
  const allKeys = ['rr','dxy','cpi','wti','vix','momentum','gld','m2'];
  const activeKeys = currentModel==='post'?['rr','dxy','cpi','wti','vix','momentum','gld']:allKeys;
  const maxBeta = Math.max(...activeKeys.map(k=>Math.abs(bm.b[allKeys.indexOf(k)+1])));
  document.getElementById('sens-tbody').innerHTML = activeKeys.map(k => {
    const fm = FACTOR_META.find(f=>f.key===k);
    const b = bm.b[allKeys.indexOf(k)+1];
    const barW = (Math.abs(b)/maxBeta*100).toFixed(0);
    const cls = b>=0?'td-pos':'td-neg';
    return `<tr>
      <td style="color:${fm.color};font-weight:600">${fm.name}</td>
      <td class="td-m">${vals[k].toFixed(fm.fmt)}${fm.unit}</td>
      <td class="td-m" style="color:${fm.color}">${b.toFixed(b>100||b<-100?0:b>10||b<-10?1:2)}</td>
      <td class="td-m ${cls}">${b>=0?'+':''}$${Math.round(Math.abs(b)).toLocaleString('en')}</td>
      <td class="td-m ${b>=0?'td-neg':'td-pos'}">${b>=0?'-':'+'}$${Math.round(Math.abs(b)).toLocaleString('en')}</td>
      <td><div class="mini-bar-wrap"><div class="mini-bar" style="width:${barW}px;max-width:80px;background:${fm.color};opacity:.7"></div><span style="font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--faint);margin-left:4px">${barW}%</span></div></td>
    </tr>`;
  }).join('');

  // Chart
  const dates = RAW.map(r=>r.date);
  const actuals = RAW.map(r=>r.gold);
  const postFairs = RAW.map(r=>r.fair_post||null);
  const fullFairs = RAW.map(r=>r.fair_full||null);

  let sD=dates,sA=actuals,sP=postFairs,sF=fullFairs;
  if(periodSlice>0){const st=RAW.length-periodSlice;sD=sD.slice(st);sA=sA.slice(st);sP=sP.slice(st);sF=sF.slice(st);}

  const datasets=[
    {label:'Actual Gold',data:sA,borderColor:'#9A6E1A',borderWidth:1.8,pointRadius:0,tension:0.3,fill:false,order:4},
    {label:'Fair (Post-2022)',data:sP,borderColor:'#C48A2A',borderWidth:1.5,borderDash:[5,3],pointRadius:0,tension:0.3,fill:false,order:2},
    {label:'Fair (Full 8F)',data:sF,borderColor:'#3A7ABF',borderWidth:1.2,borderDash:[3,2],pointRadius:0,tension:0.3,fill:false,order:3},
  ];

  if(isScenario){
    const scenLine=[...sP.map(()=>null)];
    const lastValidIdx=sP.map((v,i)=>v!=null?i:-1).filter(i=>i>=0).pop();
    if(lastValidIdx>=0) scenLine[lastValidIdx]=sP[lastValidIdx];
    scenLine.push(fair);
    const extD=[...sD,'Scenario'];
    datasets.forEach(d=>d.data=[...d.data,null]);
    datasets.push({label:'Your Scenario',data:scenLine,borderColor:'var(--teal)',borderWidth:2.5,
      pointRadius:[...scenLine.slice(0,-1).map(()=>0),10],
      pointBackgroundColor:'var(--teal)',pointBorderColor:'white',pointBorderWidth:2,
      tension:0.1,fill:false,order:1});
    sD=extD;
    document.getElementById('leg-scen').style.display='flex';
  } else {
    document.getElementById('leg-scen').style.display='none';
  }

  if(chartInst)chartInst.destroy();
  chartInst=new Chart(document.getElementById('mainChart'),{
    type:'line',data:{labels:sD,datasets},
    options:{responsive:true,interaction:{mode:'index',intersect:false},
      plugins:{legend:{display:false},tooltip:{backgroundColor:'white',borderColor:'#D8D3C8',borderWidth:1,titleColor:'#7A7468',bodyColor:'#1C1A16',padding:12,
        callbacks:{label:ctx=>{if(ctx.raw===null)return null;
          return`  ${ctx.dataset.label}: $${Math.round(ctx.raw).toLocaleString('en')}${ctx.dataset.label==='Your Scenario'?' ← Scenario':''}`;
        }}}},
      scales:{
        x:{grid:{color:'#F0EDE6'},ticks:{color:'#A8A298',font:{family:'IBM Plex Mono',size:9},maxTicksLimit:12}},
        y:{grid:{color:'#F0EDE6'},ticks:{color:'#A8A298',font:{family:'IBM Plex Mono',size:9},callback:v=>'$'+v.toLocaleString('en')}}
      }}
  });
}

function setSignal(n, color, val, desc){
  const dotColors = {green:'var(--green)',red:'var(--red)',yellow:'#D4A840',gray:'var(--faint)'};
  document.getElementById('sig-dot-'+n).style.background = dotColors[color]||'var(--faint)';
  document.getElementById('sig-val-'+n).textContent = val;
  document.getElementById('sig-val-'+n).style.color = dotColors[color];
  document.getElementById('sig-desc-'+n).textContent = desc;
}

function setPeriod(n,btn){periodSlice=n;document.querySelectorAll('.pb').forEach(b=>b.classList.remove('active'));btn.classList.add('active');recalc();}
function notify(msg){const el=document.getElementById('notif');el.textContent=msg;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),2500);}

// Init
recalc();
</script>
